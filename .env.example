# ═══════════════════════════════════════════════════════════════════════════
# Kyros Memory System - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# SECURITY NOTICE:
# - Never commit the actual .env file to version control
# - Use strong, randomly generated secrets in production
# - Rotate credentials regularly
# - Use environment-specific configurations
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace all placeholder values with your actual configuration
# 3. Ensure .env is listed in .gitignore
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# Application Configuration
# ───────────────────────────────────────────────────────────────────────────

# Application name (used in logs and monitoring)
KYROS_APP_NAME=Kyros

# Environment: development | staging | production
# - development: Enables debug features, verbose logging
# - staging: Production-like environment for testing
# - production: Optimized for performance and security
KYROS_ENVIRONMENT=development

# Debug mode: true | false
# WARNING: Never enable debug mode in production (exposes stack traces)
KYROS_DEBUG=false

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# - DEBUG: Verbose logging for development
# - INFO: Standard operational logging (recommended for production)
# - WARNING: Only warnings and errors
# - ERROR: Only errors and critical issues
KYROS_LOG_LEVEL=INFO

# ───────────────────────────────────────────────────────────────────────────
# Docker Configuration
# ───────────────────────────────────────────────────────────────────────────

# Docker build target: development | production
# - development: Includes dev dependencies, hot reload
# - production: Optimized build, minimal image size
KYROS_BUILD_TARGET=development

# ───────────────────────────────────────────────────────────────────────────
# Database Configuration (PostgreSQL) - REQUIRED
# ───────────────────────────────────────────────────────────────────────────

# PostgreSQL connection URL
# Format: postgresql+asyncpg://username:password@host:port/database
# 
# PRODUCTION CHECKLIST:
# ✓ Use strong password (min 32 characters, alphanumeric + symbols)
# ✓ Enable SSL/TLS: add ?ssl=require to the URL
# ✓ Use managed database service (AWS RDS, Google Cloud SQL, etc.)
# ✓ Enable automated backups
# ✓ Configure connection pooling appropriately
#
# Example with SSL: postgresql+asyncpg://user:pass@host:5432/db?ssl=require
KYROS_DATABASE_URL=postgresql+asyncpg://kyros:CHANGE_ME_STRONG_PASSWORD@localhost:5433/kyros

# Database connection pool size
# - Development: 5-10 connections
# - Production: 20-50 connections (adjust based on load)
KYROS_DB_POOL_SIZE=10

# Maximum overflow connections beyond pool size
# - Development: 10-20
# - Production: 30-100 (adjust based on traffic spikes)
KYROS_DB_MAX_OVERFLOW=20

# Application database password (used by migrations)
# SECURITY: Must match the password in KYROS_DATABASE_URL
# Used by: server/alembic/versions/enable_rls.py for row-level security
KYROS_DB_APP_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ───────────────────────────────────────────────────────────────────────────
# Redis Configuration - REQUIRED
# ───────────────────────────────────────────────────────────────────────────

# Redis connection URL
# Format: redis://[username:password@]host:port/database
#
# PRODUCTION CHECKLIST:
# ✓ Enable password authentication: redis://:password@host:6379/0
# ✓ Use Redis 6+ with ACL for fine-grained access control
# ✓ Enable TLS: rediss://host:6379/0 (note the 's' in rediss)
# ✓ Use managed Redis service (AWS ElastiCache, Redis Cloud, etc.)
# ✓ Configure maxmemory and eviction policy
# ✓ Enable persistence (AOF or RDB) for cache durability
#
# Example with auth: redis://:your_redis_password@localhost:6379/0
# Example with TLS: rediss://:your_redis_password@redis.example.com:6380/0
KYROS_REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────────────────────────────
# Authentication & Security - REQUIRED
# ───────────────────────────────────────────────────────────────────────────

# JWT secret key for signing tokens
# CRITICAL SECURITY:
# - Generate with: openssl rand -hex 32
# - Must be at least 32 characters
# - Never reuse across environments
# - Rotate regularly (requires re-authentication of all users)
# - Store in secrets manager in production (AWS Secrets Manager, HashiCorp Vault)
KYROS_JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_32_CHAR_SECRET_GENERATE_WITH_OPENSSL_RAND_HEX_32

# JWT signing algorithm
# Options: HS256 (symmetric) | RS256 (asymmetric)
# - HS256: Faster, simpler, uses shared secret
# - RS256: More secure, uses public/private key pair (recommended for production)
KYROS_JWT_ALGORITHM=HS256

# JWT token expiration time (in minutes)
# - Development: 60-1440 (1 hour to 1 day)
# - Production: 15-60 (15 minutes to 1 hour for security)
# Shorter expiration = more secure but more frequent re-authentication
KYROS_JWT_EXPIRY_MINUTES=60

# ───────────────────────────────────────────────────────────────────────────
# CORS (Cross-Origin Resource Sharing)
# ───────────────────────────────────────────────────────────────────────────

# Allowed origins for CORS requests
# - Development: * (allow all origins)
# - Production: Comma-separated list of specific domains
#
# SECURITY WARNING: Never use * in production!
#
# Examples:
# - Single domain: https://app.example.com
# - Multiple domains: https://app.example.com,https://admin.example.com
# - With subdomains: https://*.example.com (if supported by your framework)
KYROS_ALLOWED_ORIGINS=*

# ───────────────────────────────────────────────────────────────────────────
# Embedding Models - REQUIRED
# ───────────────────────────────────────────────────────────────────────────

# Primary embedding model
# Default: all-MiniLM-L6-v2 (384 dimensions, ~80MB)
# - Downloaded automatically on first run from HuggingFace
# - No API key required
# - Runs locally for privacy and cost efficiency
#
# Alternative models:
# - all-mpnet-base-v2 (768 dimensions, ~420MB, higher quality)
# - paraphrase-multilingual-MiniLM-L12-v2 (384 dimensions, multilingual)
# - text-embedding-ada-002 (OpenAI, requires API key, 1536 dimensions)
#
# PRODUCTION CONSIDERATIONS:
# - Larger models = better quality but slower inference
# - Consider GPU acceleration for high-throughput scenarios
# - Model is cached after first download
KYROS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding dimension (must match the model)
# - all-MiniLM-L6-v2: 384
# - all-mpnet-base-v2: 768
# - text-embedding-ada-002: 1536
KYROS_EMBEDDING_DIMENSION=384

# Secondary embedding model (optional)
# Used for dual-embedding strategy to enable model portability
# Leave empty to disable dual embeddings
# Example: all-mpnet-base-v2
KYROS_SECONDARY_EMBEDDING_MODEL=

# ───────────────────────────────────────────────────────────────────────────
# LLM Provider API Keys - OPTIONAL
# ───────────────────────────────────────────────────────────────────────────

# LLM API keys are OPTIONAL - the core memory engine works without them
# Required only for:
# - Causal edge extraction (understanding cause-effect relationships)
# - LLM-based memory compression (summarization)
# - Advanced semantic analysis
#
# SECURITY BEST PRACTICES:
# ✓ Store API keys in secrets manager (AWS Secrets Manager, HashiCorp Vault)
# ✓ Use environment-specific keys (separate dev/staging/prod keys)
# ✓ Enable API key rotation
# ✓ Monitor API usage and set spending limits
# ✓ Use least-privilege API keys (read-only when possible)

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Models: gpt-4, gpt-3.5-turbo, text-embedding-ada-002
OPENAI_API_KEY=

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
# Models: gemini-pro, gemini-pro-vision
GEMINI_API_KEY=

# Anthropic API Key
# Get from: https://console.anthropic.com/
# Models: claude-3-opus, claude-3-sonnet, claude-3-haiku
ANTHROPIC_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Proxy Server Configuration - OPTIONAL
# ───────────────────────────────────────────────────────────────────────────

# Proxy admin token for runtime configuration API
# Required for: GET/PUT /proxy/config endpoints
# If unset, runtime proxy configuration endpoints are disabled
#
# SECURITY:
# - Generate with: openssl rand -hex 32
# - Use different token than JWT secret
# - Restrict access to admin users only
# - Rotate regularly
#
# Usage: Include in Authorization header: Bearer <token>
KYROS_PROXY_ADMIN_TOKEN=

# ───────────────────────────────────────────────────────────────────────────
# Memory Compression - OPTIONAL
# ───────────────────────────────────────────────────────────────────────────

# Compression strategy
# Options:
# - extractive: Fast local compression (no API key needed, default)
# - openai: Use OpenAI for summarization (requires OPENAI_API_KEY)
# - anthropic: Use Anthropic Claude (requires ANTHROPIC_API_KEY)
# - gemini: Use Google Gemini (requires GEMINI_API_KEY)
#
# COST CONSIDERATIONS:
# - extractive: Free, fast, but less sophisticated
# - LLM-based: Better quality but costs API credits
KYROS_COMPRESSION_LLM_PROVIDER=extractive

# LLM API key for compression (if using LLM-based compression)
# Can be same as provider keys above or separate key with lower rate limits
KYROS_COMPRESSION_LLM_API_KEY=

# LLM model for compression
# Examples:
# - OpenAI: gpt-3.5-turbo, gpt-4
# - Anthropic: claude-3-haiku, claude-3-sonnet
# - Gemini: gemini-pro
KYROS_COMPRESSION_LLM_MODEL=

# ───────────────────────────────────────────────────────────────────────────
# Stripe Billing Integration - OPTIONAL
# ───────────────────────────────────────────────────────────────────────────

# Only needed if building a SaaS product on top of Kyros
# Enables usage-based billing and subscription management
#
# PRODUCTION CHECKLIST:
# ✓ Use separate test/live keys for dev/prod
# ✓ Enable webhook signature verification
# ✓ Configure webhook endpoints in Stripe dashboard
# ✓ Test webhook handling in staging environment
# ✓ Monitor failed payments and subscription events

# Stripe API Key
# Get from: https://dashboard.stripe.com/apikeys
# Use test key (sk_test_...) for development
# Use live key (sk_live_...) for production
KYROS_STRIPE_API_KEY=

# Stripe Webhook Secret
# Get from: https://dashboard.stripe.com/webhooks
# Used to verify webhook signatures for security
# Format: whsec_...
KYROS_STRIPE_WEBHOOK_SECRET=

# ───────────────────────────────────────────────────────────────────────────
# Memory Archival (S3) - OPTIONAL
# ───────────────────────────────────────────────────────────────────────────

# S3 archival for deleted memories
# Enables compliance with data retention policies
# Deleted memories are moved to S3 instead of permanent deletion
#
# PRODUCTION CHECKLIST:
# ✓ Use separate buckets for dev/staging/prod
# ✓ Enable bucket versioning for data recovery
# ✓ Configure lifecycle policies for cost optimization
# ✓ Enable server-side encryption (SSE-S3 or SSE-KMS)
# ✓ Set up bucket access logging
# ✓ Configure CORS if accessing from browser
# ✓ Use IAM roles instead of access keys when possible

# S3 bucket name for archived memories
# KYROS_ARCHIVE_BUCKET=kyros-memory-archive

# AWS region for S3 bucket
# AWS_REGION=us-east-1

# AWS credentials (use IAM roles in production instead)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Additional Production Configuration
# ───────────────────────────────────────────────────────────────────────────

# Public site URL (used for metadata, redirects, etc.)
# NEXT_PUBLIC_SITE_URL=https://kyros.ai

# API base URL (used by SDKs and frontend)
# NEXT_PUBLIC_API_URL=https://api.kyros.ai

# ═══════════════════════════════════════════════════════════════════════════
# End of Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# PRODUCTION DEPLOYMENT CHECKLIST:
# ☐ Replace all CHANGE_ME placeholders with strong, random values
# ☐ Set KYROS_ENVIRONMENT=production
# ☐ Set KYROS_DEBUG=false
# ☐ Set KYROS_LOG_LEVEL=INFO or WARNING
# ☐ Configure KYROS_ALLOWED_ORIGINS with specific domains (not *)
# ☐ Enable database SSL/TLS
# ☐ Enable Redis authentication and TLS
# ☐ Use secrets manager for sensitive values
# ☐ Set up monitoring and alerting
# ☐ Configure automated backups
# ☐ Test disaster recovery procedures
# ☐ Review and apply security headers
# ☐ Enable rate limiting
# ☐ Set up log aggregation
# ☐ Configure health check endpoints
# ☐ Document runbook procedures
#
# SECURITY REMINDERS:
# - Never commit .env to version control
# - Rotate secrets regularly (every 90 days minimum)
# - Use different credentials for each environment
# - Enable MFA on all cloud provider accounts
# - Audit access logs regularly
# - Keep dependencies updated
# - Run security scans regularly
#
# ═══════════════════════════════════════════════════════════════════════════
