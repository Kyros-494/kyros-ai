# ═══════════════════════════════════════════════════════════════════════════
# Kyros Memory System - Required Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL with pgvector)
KYROS_DATABASE_URL=postgresql+asyncpg://kyros:CHANGE_ME_STRONG_PASSWORD@localhost:5433/kyros
KYROS_DB_APP_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KYROS_DB_POOL_SIZE=10
KYROS_DB_MAX_OVERFLOW=20

# ── Cache (Redis)
KYROS_REDIS_URL=redis://localhost:6379/0

# ── Security & Authentication
# Secret key must be at least 32 characters (e.g. generated via `openssl rand -hex 32`)
KYROS_JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_32_CHAR_SECRET_GENERATE_WITH_OPENSSL_RAND_HEX_32
KYROS_JWT_EXPIRY_MINUTES=60

# ── Auto-Bootstrapping (Development/Test only)
KYROS_ENVIRONMENT=development
KYROS_API_KEY=mk_live_default_dev_key_123456
KYROS_ADMIN_TOKEN=admin-secret-token

# ── LLM Providers (Optional - required for causal reasoning & summaries)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
