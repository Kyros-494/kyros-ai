{
  "name": "@kyros/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Kyros — persistent memory for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/"
  },
  "keywords": ["ai", "agents", "memory", "llm", "rag", "kyros"],
  "author": "Kyros Team <team@kyros.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kyros-494/kyros-ai"
  },
  "files": ["dist/"],
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.6.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.1.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^8.57.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}
