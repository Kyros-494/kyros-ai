# ═══════════════════════════════════════════════════════════════════════════
# Kyros Server - Test Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Purpose: Test-specific environment variables for CI/CD and local testing
# Usage: Loaded by pytest fixtures in tests/conftest.py
#
# SECURITY NOTE:
# - Use test-specific credentials (never production credentials)
# - Test databases should be isolated and ephemeral
# - Safe to commit to version control (no real secrets)
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# Application Configuration
# ───────────────────────────────────────────────────────────────────────────

KYROS_APP_NAME=Kyros-Test
KYROS_ENVIRONMENT=test
KYROS_DEBUG=true
KYROS_LOG_LEVEL=DEBUG

# ───────────────────────────────────────────────────────────────────────────
# Database Configuration (Test Database)
# ───────────────────────────────────────────────────────────────────────────

# Test database - isolated from development/production
# Note: Tests may create/drop this database
KYROS_DATABASE_URL=postgresql+asyncpg://kyros:test_password@localhost:5433/kyros_test
KYROS_DB_POOL_SIZE=5
KYROS_DB_MAX_OVERFLOW=10
KYROS_DB_APP_PASSWORD=test_password

# ───────────────────────────────────────────────────────────────────────────
# Redis Configuration (Test Redis)
# ───────────────────────────────────────────────────────────────────────────

# Use separate Redis database for tests (db 1 instead of 0)
KYROS_REDIS_URL=redis://localhost:6379/1

# ───────────────────────────────────────────────────────────────────────────
# Authentication & Security (Test Credentials)
# ───────────────────────────────────────────────────────────────────────────

# Test JWT secret - NOT secure, only for testing
KYROS_JWT_SECRET_KEY=test_jwt_secret_key_not_for_production_use_only_testing
KYROS_JWT_ALGORITHM=HS256
KYROS_JWT_EXPIRY_MINUTES=60

# ───────────────────────────────────────────────────────────────────────────
# CORS (Allow All for Testing)
# ───────────────────────────────────────────────────────────────────────────

KYROS_ALLOWED_ORIGINS=*

# ───────────────────────────────────────────────────────────────────────────
# Embedding Models (Use Smallest Model for Speed)
# ───────────────────────────────────────────────────────────────────────────

# Use smallest model for faster tests
KYROS_EMBEDDING_MODEL=all-MiniLM-L6-v2
KYROS_EMBEDDING_DIMENSION=384
KYROS_SECONDARY_EMBEDDING_MODEL=

# ───────────────────────────────────────────────────────────────────────────
# LLM Provider API Keys (Mock/Empty for Tests)
# ───────────────────────────────────────────────────────────────────────────

# Leave empty - tests should mock LLM calls
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Optional Features (Disabled for Tests)
# ───────────────────────────────────────────────────────────────────────────

KYROS_PROXY_ADMIN_TOKEN=
KYROS_COMPRESSION_LLM_PROVIDER=extractive
KYROS_COMPRESSION_LLM_API_KEY=
KYROS_COMPRESSION_LLM_MODEL=
KYROS_STRIPE_API_KEY=
KYROS_STRIPE_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# Test-Specific Notes:
# - This file is safe to commit (no real secrets)
# - Tests should create/cleanup their own data
# - Use separate database and Redis instance for isolation
# - Mock external API calls (LLMs, Stripe, S3)
# ═══════════════════════════════════════════════════════════════════════════
